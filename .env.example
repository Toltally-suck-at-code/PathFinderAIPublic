# Convex Configuration
# Get your deployment URL from https://dashboard.convex.dev
CONVEX_DEPLOYMENT=your-deployment-name
# Important: no trailing slash (e.g. https://your-deployment.convex.cloud)
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud

# Google OAuth (for Convex Auth)
# Create credentials at https://console.cloud.google.com/apis/credentials
AUTH_GOOGLE_ID=your-google-client-id
AUTH_GOOGLE_SECRET=your-google-client-secret

# Pilot auth controls
# Comma-separated domains allowed to sign in (without @). Defaults to stu.vinschool.edu.vn,vinschool.edu.vn
ALLOWED_EMAIL_DOMAINS=stu.vinschool.edu.vn,vinschool.edu.vn
# Optional bootstrap role assignment for first pilot setup (comma-separated full emails)
PILOT_ADMIN_EMAILS=
PILOT_COUNSELOR_EMAILS=

# Gemini AI
# Get your API key from https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key
# Optional override, defaults to gemini-2.5-flash
GEMINI_MODEL=gemini-2.5-flash
